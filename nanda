class DnCNN(nn.Module):
    """
    DnCNN: Beyond a Gaussian Denoiser (Zhang et al., 2017)
    - 17 layer convolutional network
    - Residual learning: output = input - predicted_noise
    - Sangat efektif untuk SEM image noise
    """
    def __init__(self, channels=1, num_layers=17, features=64):
        super().__init__()
        layers = [nn.Conv2d(channels, features, 3, padding=1), nn.ReLU(inplace=True)]
        for _ in range(num_layers - 2):
            layers += [
                nn.Conv2d(features, features, 3, padding=1, bias=False),
                nn.BatchNorm2d(features),
                nn.ReLU(inplace=True)
            ]
        layers.append(nn.Conv2d(features, channels, 3, padding=1))
        self.net = nn.Sequential(*layers)

    def forward(self, x):
        return x - self.net(x)  # residual: hapus noise dari input


def download_dncnn_weights(save_path: str):
    """
    Download pretrained DnCNN weights dari GitHub.
    Source: https://github.com/cszn/KAIR (official implementation)
    """
    import requests
    url = "https://github.com/cszn/KAIR/releases/download/v1.0/dncnn_gray_blind.pth"
    print(f"Downloading DnCNN weights...")
    r = requests.get(url, stream=True)
    with open(save_path, 'wb') as f:
        for chunk in r.iter_content(chunk_size=8192):
            f.write(chunk)
    print(f"  Saved: {save_path}")


def load_dncnn(weights_path: str = None) -> DnCNN:
    """Load DnCNN model. Jika weights tidak ada, download otomatis."""
    if weights_path is None:
        weights_path = os.path.join(MODEL_DIR, "dncnn_gray_blind.pth")

    if not os.path.exists(weights_path):
        download_dncnn_weights(weights_path)

    model = DnCNN(channels=1, num_layers=20)  # blind model pakai 20 layers
    state = torch.load(weights_path, map_location=DEVICE)

    # Handle berbagai format state dict
    if 'params' in state:
        state = state['params']
    model.load_state_dict(state, strict=False)
    model.eval().to(DEVICE)
    print("DnCNN loaded!")
    return model


@torch.no_grad()
def denoise_dncnn(img: np.ndarray, model: DnCNN) -> np.ndarray:
    """
    Denoise SEM image menggunakan DnCNN.

    Args:
        img  : Grayscale image (H x W), uint8 [0-255]
        model: DnCNN model yang sudah di-load

    Returns:
        Denoised image, uint8 [0-255]
    """
    # SwinIR grayscale pakai img_range=255 → input dalam range [0, 255]
    x = torch.from_numpy(img.astype(np.float32))
    x = x.unsqueeze(0).unsqueeze(0).to(DEVICE)  # [1,1,H,W]

    # Pad supaya divisible by window_size (8)
    h, w = x.shape[2], x.shape[3]
    pad_h = (8 - h % 8) % 8
    pad_w = (8 - w % 8) % 8
    x = F.pad(x, (0, pad_w, 0, pad_h), mode='reflect')

    out = model(x)
    out = out[:, :, :h, :w]  # unpad
    out = out.squeeze().cpu().numpy()
    out = np.clip(out, 0, 255).astype(np.uint8)
    return out


