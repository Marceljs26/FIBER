def load_sem_image(path: str, crop_bottom: int = 60) -> np.ndarray:
    """Load dan crop SEM image."""
    img = np.array(Image.open(path).convert('L'))
    return img[:-crop_bottom, :]


def post_process(img: np.ndarray,
                 clahe_clip: float = 1.0,
                 gamma: float = 1.03) -> np.ndarray:
    """
    Post-processing ringan setelah DL denoising:
    - CLAHE soft untuk tingkatkan kontras lokal
    - Gamma correction untuk sesuaikan brightness
    """
    clahe = cv2.createCLAHE(clipLimit=clahe_clip, tileGridSize=(16, 16))
    img = clahe.apply(img)
    lut = np.array([(i / 255.0) ** gamma * 255 for i in range(256)], dtype=np.uint8)
    return cv2.LUT(img, lut)


def denoise_sem(input_path: str,
                model_type: str = "dncnn",
                noise_level: int = 25,
                apply_postprocess: bool = True,
                crop_bottom: int = 60) -> np.ndarray:
    """
    Pipeline lengkap: Load → DL Denoise → Post-process → Save

    Args:
        input_path      : Path ke file SEM (.tif / .png)
        model_type      : "dncnn" atau "swinir"
        noise_level     : Untuk SwinIR: 15, 25, atau 50
        apply_postprocess: Tambah CLAHE+gamma setelah DL
        crop_bottom     : Pixel info bar yang di-crop

    Returns:
        Denoised image (numpy array)
    """
    print(f"\n{'='*55}")
    print(f"  SEM DL Denoising Pipeline")
    print(f"  Model: {model_type.upper()} | Device: {DEVICE}")
    print(f"{'='*55}")

    # Load
    img = load_sem_image(input_path, crop_bottom)
    print(f"  Input: {img.shape} | {input_path}")

    # Load model & denoise
    if model_type == "dncnn":
        model = load_dncnn()
        denoised = denoise_dncnn(img, model)

    elif model_type == "swinir":
        model = load_swinir(noise_level)
        denoised = denoise_swinir(img, model)

    else:
        raise ValueError(f"Unknown model: {model_type}. Use 'dncnn' or 'swinir'")

    # Post-process
    if apply_postprocess:
        result = post_process(denoised, clahe_clip=1.0, gamma=1.03)
    else:
        result = denoised

    # Stats
    def lap(im): return cv2.Laplacian(im.astype(np.float64), cv2.CV_64F).var()
    print(f"\n  Original : lap={lap(img):.0f} | std={img.std():.1f} | mean={img.mean():.1f}")
    print(f"  Denoised : lap={lap(result):.0f} | std={result.std():.1f} | mean={result.mean():.1f}")

    # Save
    fname = os.path.splitext(os.path.basename(input_path))[0]
    out_path = os.path.join(OUTPUT_DIR, f"{fname}_{model_type}_denoised.png")
    cv2.imwrite(out_path, result)
    print(f"  Saved: {out_path}")

    # Visual comparison
    fig, axes = plt.subplots(1, 2, figsize=(14, 6))
    axes[0].imshow(img, cmap='gray')
    axes[0].set_title(f"Original\nlap={lap(img):.0f} | std={img.std():.1f}")
    axes[0].axis('off')
    axes[1].imshow(result, cmap='gray')
    axes[1].set_title(f"DL Denoised ({model_type.upper()})\nlap={lap(result):.0f} | std={result.std():.1f}")
    axes[1].axis('off')
    plt.tight_layout()
    fig_path = os.path.join(OUTPUT_DIR, f"{fname}_{model_type}_comparison.png")
    plt.savefig(fig_path, dpi=150, bbox_inches='tight')
    plt.close()
    print(f"  Comparison: {fig_path}")

    return result


def batch_denoise(input_folder: str, model_type: str = "swinir",
                  noise_level: int = 25):
    """
    Batch processing semua TIF/PNG dalam satu folder.

    Contoh:
        batch_denoise("./sem_images/", model_type="swinir", noise_level=25)
    """
    import glob
    files = glob.glob(os.path.join(input_folder, "*.tif")) + \
            glob.glob(os.path.join(input_folder, "*.png"))

    print(f"Found {len(files)} files")

    # Load model sekali untuk semua file
    if model_type == "dncnn":
        model = load_dncnn()
        denoise_fn = lambda img: denoise_dncnn(img, model)
    else:
        model = load_swinir(noise_level)
        denoise_fn = lambda img: denoise_swinir(img, model)

    for fpath in files:
        img = load_sem_image(fpath)
        denoised = denoise_fn(img)
        result = post_process(denoised)
        fname = os.path.splitext(os.path.basename(fpath))[0]
        cv2.imwrite(os.path.join(OUTPUT_DIR, f"{fname}_denoised.png"), result)
        print(f"  Done: {fname}")

    print(f"\nAll done! Results in: {OUTPUT_DIR}")


