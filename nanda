def setup_swinir():
    """
    Setup SwinIR dari repo resmi.
    Jalankan ini SEKALI untuk download repo dan weights.
    
    Weights yang dipakai: GrayDN (grayscale denoising)
    File: 004_grayDN_DFWB_s128w8_SwinIR-M_noise{level}.pth
    """
    import subprocess
    import requests

    print("Setting up SwinIR...")

    # Clone repo jika belum ada
    swinir_dir = os.path.join(os.path.dirname(os.path.abspath(__file__)), "SwinIR")
    if not os.path.exists(swinir_dir):
        subprocess.run(["git", "clone",
                        "https://github.com/JingyunLiang/SwinIR.git",
                        swinir_dir], check=True)
        print("  Repo cloned!")

    # Weights yang BENAR untuk GRAYSCALE denoising
    weights = {
        "swinir_denoising_gray_noise15.pth":
            "https://github.com/JingyunLiang/SwinIR/releases/download/v0.0/"
            "004_grayDN_DFWB_s128w8_SwinIR-M_noise15.pth",
        "swinir_denoising_gray_noise25.pth":
            "https://github.com/JingyunLiang/SwinIR/releases/download/v0.0/"
            "004_grayDN_DFWB_s128w8_SwinIR-M_noise25.pth",
        "swinir_denoising_gray_noise50.pth":
            "https://github.com/JingyunLiang/SwinIR/releases/download/v0.0/"
            "004_grayDN_DFWB_s128w8_SwinIR-M_noise50.pth",
    }

    for fname, url in weights.items():
        fpath = os.path.join(MODEL_DIR, fname)
        if not os.path.exists(fpath):
            print(f"  Downloading {fname}...")
            r = requests.get(url, stream=True)
            with open(fpath, 'wb') as f:
                for chunk in r.iter_content(8192):
                    f.write(chunk)
            print(f"  Saved: {fname}")

    print("SwinIR setup complete!")


def load_swinir(noise_level: int = 25):
    """
    Load SwinIR model untuk grayscale denoising.

    Args:
        noise_level: 15, 25, atau 50 — sesuaikan dengan tingkat noise SEM kamu
                     SEM biasanya cocok dengan 25 atau 50

    Returns:
        SwinIR model siap pakai
    """
    import sys
    # Path ke folder SwinIR (di sebelah script ini)
    script_dir = os.path.dirname(os.path.abspath(__file__))
    swinir_dir = os.path.join(script_dir, "SwinIR")
    sys.path.insert(0, swinir_dir)
    from models.network_swinir import SwinIR

    weights_path = os.path.join(MODEL_DIR, f"swinir_denoising_gray_noise{noise_level}.pth")
    if not os.path.exists(weights_path):
        setup_swinir()

    # in_chans=1 untuk grayscale SEM image
    model = SwinIR(
        upscale=1,
        in_chans=1,
        img_size=128,
        window_size=8,
        img_range=255.0,
        depths=[6, 6, 6, 6, 6, 6],
        embed_dim=180,
        num_heads=[6, 6, 6, 6, 6, 6],
        mlp_ratio=2,
        upsampler='',
        resi_connection='1conv'
    )

    state = torch.load(weights_path, map_location=DEVICE)
    if 'params' in state:
        state = state['params']
    model.load_state_dict(state, strict=True)
    model.eval().to(DEVICE)
    print(f"SwinIR grayscale (noise={noise_level}) loaded!")
    return model


@torch.no_grad()
def denoise_swinir(img: np.ndarray, model, tile_size: int = 256,
                   tile_overlap: int = 32) -> np.ndarray:
    """
    Denoise SEM image menggunakan SwinIR dengan tile-based inference.
    Tile digunakan supaya gambar besar tidak OOM di GPU/RAM.

    Args:
        img         : Grayscale uint8 [0-255]
        model       : SwinIR model
        tile_size   : Ukuran tile (256 untuk RAM 8GB, 512 untuk 16GB+)
        tile_overlap: Overlap antar tile untuk menghindari artifacts

    Returns:
        Denoised image, uint8 [0-255]
    """
    h, w = img.shape
    x = torch.from_numpy(img.astype(np.float32) / 255.0)
    x = x.unsqueeze(0).unsqueeze(0).to(DEVICE)  # [1,1,H,W]

    # Tile-based inference
    stride = tile_size - tile_overlap
    h_idx_list = list(range(0, h - tile_size, stride)) + [max(0, h - tile_size)]
    w_idx_list = list(range(0, w - tile_size, stride)) + [max(0, w - tile_size)]

    output = torch.zeros_like(x)
    count  = torch.zeros_like(x)

    for h_idx in h_idx_list:
        for w_idx in w_idx_list:
            h_end = min(h_idx + tile_size, h)
            w_end = min(w_idx + tile_size, w)
            h_s   = h_end - tile_size
            w_s   = w_end - tile_size

            tile_in = x[:, :, h_s:h_end, w_s:w_end]
            tile_out = model(tile_in)
            output[:, :, h_s:h_end, w_s:w_end] += tile_out
            count [:, :, h_s:h_end, w_s:w_end] += 1

    output = output / count
    out = output.squeeze().cpu().numpy()
    out = np.clip(out * 255, 0, 255).astype(np.uint8)
    return out


